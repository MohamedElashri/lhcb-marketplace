{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Generated Codex plugin manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "description",
    "author",
    "license",
    "keywords",
    "interface"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "skills": {
      "const": "./skills/"
    },
    "mcpServers": {
      "const": "./.mcp.json"
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "displayName",
        "shortDescription",
        "longDescription",
        "developerName",
        "category",
        "capabilities",
        "defaultPrompt"
      ],
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "shortDescription": {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        },
        "longDescription": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500
        },
        "developerName": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "type": "array",
          "items": {
            "enum": ["Skills", "MCP"]
          },
          "uniqueItems": true
        },
        "defaultPrompt": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        }
      }
    }
  }
}
