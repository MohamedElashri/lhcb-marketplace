{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhcb-agent-marketplace.example/schemas/maintenance.schema.json",
  "title": "Marketplace maintenance inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "owner",
    "verification_policy",
    "skills",
    "integrations",
    "follow_ups"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "owner": {
      "$ref": "#/$defs/owner"
    },
    "verification_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cadence_months", "next_review", "early_review_triggers"],
      "properties": {
        "cadence_months": {
          "const": 6
        },
        "next_review": {
          "type": "string",
          "format": "date"
        },
        "early_review_triggers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "plugin",
          "maintainer",
          "reviewer",
          "last_verified",
          "next_verification",
          "runtime_evidence"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "plugin": {
            "const": "lhcb"
          },
          "maintainer": {
            "$ref": "#/$defs/owner"
          },
          "reviewer": {
            "$ref": "#/$defs/owner"
          },
          "last_verified": {
            "type": "string",
            "format": "date"
          },
          "next_verification": {
            "type": "string",
            "format": "date"
          },
          "runtime_evidence": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "integrations": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "plugin",
          "package",
          "owner",
          "last_verified",
          "next_verification",
          "supported_surface"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "plugin": {
            "type": "string"
          },
          "package": {
            "type": "string"
          },
          "owner": {
            "$ref": "#/$defs/owner"
          },
          "last_verified": {
            "type": "string",
            "format": "date"
          },
          "next_verification": {
            "type": "string",
            "format": "date"
          },
          "supported_surface": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "follow_ups": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "issue", "owner", "due", "scope"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "issue": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://github\\.com/"
          },
          "owner": {
            "$ref": "#/$defs/owner"
          },
          "due": {
            "type": "string",
            "format": "date"
          },
          "scope": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  },
  "$defs": {
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "github"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "github": {
          "type": "string",
          "pattern": "^@[A-Za-z0-9-]+$"
        }
      }
    }
  }
}
