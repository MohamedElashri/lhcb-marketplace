{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhcb-agent-marketplace.example/schemas/plugin.schema.json",
  "title": "Canonical marketplace plugin metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "display_name",
    "description",
    "version",
    "author",
    "license",
    "interface",
    "capabilities"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "short_description",
        "long_description",
        "category",
        "default_prompts"
      ],
      "properties": {
        "short_description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 100
        },
        "long_description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "default_prompts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skills", "mcp"],
      "properties": {
        "skills": {
          "type": "boolean"
        },
        "mcp": {
          "type": "boolean"
        }
      }
    }
  }
}
