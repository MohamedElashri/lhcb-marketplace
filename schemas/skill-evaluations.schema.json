{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhcb-agent-marketplace.example/schemas/skill-evaluations.schema.json",
  "title": "Skill routing evaluation cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cases"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "prompt",
          "expected_skill",
          "forbidden_skills",
          "expected_outcome"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "prompt": {
            "type": "string",
            "minLength": 10
          },
          "expected_skill": {
            "type": ["string", "null"]
          },
          "forbidden_skills": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "expected_outcome": {
            "enum": ["route", "defer", "reject-legacy-default"]
          }
        }
      }
    }
  }
}
