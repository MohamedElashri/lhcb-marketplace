{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhcb-agent-marketplace.example/schemas/marketplace.schema.json",
  "title": "LHCb Agent Marketplace catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "owner", "plugins"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "name": {
      "$ref": "#/$defs/name"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path"],
        "properties": {
          "name": {
            "$ref": "#/$defs/name"
          },
          "path": {
            "type": "string",
            "pattern": "^plugins/[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        }
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
