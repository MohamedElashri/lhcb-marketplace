{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhcb-agent-marketplace.example/schemas/provenance.schema.json",
  "title": "Adapted content provenance",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "items"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "local_path",
          "upstream_repository",
          "upstream_commit",
          "upstream_path",
          "license",
          "modifications",
          "maintainer"
        ],
        "properties": {
          "local_path": {
            "type": "string",
            "minLength": 1,
            "not": {
              "pattern": "(^|/)\\.\\.(/|$)"
            }
          },
          "upstream_repository": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "upstream_commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "upstream_path": {
            "type": "string",
            "minLength": 1
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "copyright": {
            "type": "string",
            "minLength": 1
          },
          "modifications": {
            "type": "string",
            "minLength": 10
          },
          "maintainer": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
