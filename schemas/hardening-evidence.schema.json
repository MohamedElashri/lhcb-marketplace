{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lhcb-agent-marketplace.example/schemas/hardening-evidence.schema.json",
  "title": "Hardening completion evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "completed_at",
    "routing_measurement",
    "runtime_revalidation",
    "audits",
    "cds_search",
    "open_critical_issues",
    "known_limitations"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "completed_at": {
      "type": "string",
      "format": "date"
    },
    "routing_measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "accepted_accuracy", "clients"],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 20
        },
        "accepted_accuracy": {
          "type": "number",
          "minimum": 0.8,
          "maximum": 1
        },
        "clients": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["client", "version", "model", "predictions"],
            "properties": {
              "client": {
                "enum": ["codex", "claude-code"]
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "model": {
                "type": "string",
                "minLength": 1
              },
              "predictions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "selected_skill"],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "selected_skill": {
                      "type": ["string", "null"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "runtime_revalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revalidated_at",
        "host",
        "preserved_evidence",
        "fresh_run_observation"
      ],
      "properties": {
        "revalidated_at": {
          "type": "string",
          "format": "date"
        },
        "host": {
          "type": "string",
          "minLength": 5
        },
        "preserved_evidence": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "status"],
            "properties": {
              "path": {
                "type": "string"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "status": {
                "const": "passed"
              }
            }
          }
        },
        "fresh_run_observation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "stage", "reason", "impact"],
          "properties": {
            "status": {
              "enum": ["passed", "blocked-external"]
            },
            "stage": {
              "type": "string"
            },
            "reason": {
              "type": "string",
              "minLength": 10
            },
            "impact": {
              "type": "string",
              "minLength": 10
            }
          }
        }
      }
    },
    "audits": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "evidence"],
        "properties": {
          "name": {
            "enum": ["provenance", "dependencies", "secrets", "documentation"]
          },
          "status": {
            "const": "passed"
          },
          "evidence": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "cds_search": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "retested_at",
        "package",
        "anonymous_search",
        "decision",
        "supported_surface",
        "owner",
        "follow_up_milestone"
      ],
      "properties": {
        "retested_at": {
          "type": "string",
          "format": "date"
        },
        "package": {
          "const": "cds-mcp==0.1.2"
        },
        "anonymous_search": {
          "const": "failed"
        },
        "decision": {
          "const": "excluded-from-v0.1-support"
        },
        "supported_surface": {
          "type": "string",
          "minLength": 10
        },
        "owner": {
          "type": "string",
          "minLength": 3
        },
        "follow_up_milestone": {
          "type": "string",
          "minLength": 15
        }
      }
    },
    "open_critical_issues": {
      "type": "array",
      "maxItems": 0
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["limitation", "owner", "milestone"],
        "properties": {
          "limitation": {
            "type": "string",
            "minLength": 10
          },
          "owner": {
            "type": "string",
            "minLength": 3
          },
          "milestone": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  }
}
