{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Generated stdio MCP configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["mcpServers"],
  "properties": {
    "mcpServers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "command", "args"],
        "properties": {
          "type": {
            "const": "stdio"
          },
          "command": {
            "const": "uvx"
          },
          "args": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
