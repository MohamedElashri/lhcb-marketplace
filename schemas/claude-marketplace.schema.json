{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Generated Claude marketplace",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "owner", "metadata", "plugins"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description",
          "author",
          "source",
          "version",
          "keywords"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "author": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "format": "uri",
                "pattern": "^https://"
              }
            }
          },
          "source": {
            "type": "string",
            "pattern": "^\\./plugins/[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "version": {
            "type": "string"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "skills": {
            "const": "./skills/"
          }
        }
      }
    }
  }
}
