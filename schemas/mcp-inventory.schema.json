{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pinned MCP dependency inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verified_at", "servers"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "verified_at": {
      "type": "string",
      "format": "date"
    },
    "servers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "plugin",
          "package",
          "version",
          "executable",
          "source",
          "license",
          "requires_python",
          "runtime_python",
          "wheel_sha256",
          "read_only",
          "public_without_credentials",
          "required_env",
          "optional_env",
          "args",
          "smoke"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "plugin": {
            "enum": ["cern-code", "root-analysis", "hep-research"]
          },
          "package": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
          },
          "executable": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "source": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "requires_python": {
            "type": "string",
            "minLength": 1
          },
          "runtime_python": {
            "const": "3.12"
          },
          "wheel_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "read_only": {
            "const": true
          },
          "public_without_credentials": {
            "type": "boolean"
          },
          "required_env": {
            "$ref": "#/$defs/environment"
          },
          "optional_env": {
            "$ref": "#/$defs/environment"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "smoke": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tool", "arguments"],
            "properties": {
              "tool": {
                "type": "string",
                "minLength": 1
              },
              "arguments": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "environment": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*$"
      },
      "uniqueItems": true
    }
  }
}
