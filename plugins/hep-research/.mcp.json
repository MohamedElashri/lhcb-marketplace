      "args": [
        "--python",
        "3.12",
        "--from",
        "hepdata-mcp==0.1.0",
        "hepdata-mcp",
        "--transport",
        "stdio"
      ]
    },
    "cds": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--python",
        "3.12",
        "--from",
        "cds-mcp==0.1.2",
        "cds-mcp"
      ]
    }
  }
